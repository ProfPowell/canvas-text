{
  "name": "@profpowell/canvas-text",
  "version": "0.2.0",
  "description": "Stand-alone web component that composites rich text and images onto a canvas",
  "type": "module",
  "main": "dist/canvas-text.js",
  "module": "dist/canvas-text.js",
  "types": "canvas-text.d.ts",
  "exports": {
    ".": {
      "types": "./canvas-text.d.ts",
      "import": "./dist/canvas-text.js",
      "default": "./dist/canvas-text.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "canvas-text.d.ts",
    "custom-elements.json",
    "README.md",
    "LICENSE"
  ],
  "customElements": "custom-elements.json",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"test/**/*.js\"",
    "prepublishOnly": "npm run build",
    "site:dev": "vite --config vite.site.config.js",
    "site:build": "npm run build && vite build --config vite.site.config.js",
    "site:preview": "vite preview --config vite.site.config.js"
  },
  "keywords": [
    "web-component",
    "custom-element",
    "canvas",
    "render-tag",
    "meme",
    "profpowell-web-components"
  ],
  "author": "Prof Thomas Powell",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ProfPowell/canvas-text.git"
  },
  "bugs": {
    "url": "https://github.com/ProfPowell/canvas-text/issues"
  },
  "homepage": "https://profpowell.github.io/canvas-text/",
  "peerDependencies": {
    "render-tag": "^0.1.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.57.0",
    "@profpowell/browser-window": "^1.4.7",
    "@profpowell/code-block": "^2.9.0",
    "eslint": "^9.0.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.0.0",
    "render-tag": "^0.1.7",
    "vanilla-breeze": "^0.1.4",
    "vite": "^6.0.0"
  }
}
